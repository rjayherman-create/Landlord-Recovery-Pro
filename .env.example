# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
# On Railway: use ${{Postgres.DATABASE_URL}} to reference the linked Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Both keys come from the Clerk dashboard (or the Replit Auth pane)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Exposed to the Vite frontend bundle — must start with VITE_
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Production proxy URL — routes Clerk Frontend API calls through your own domain.
# Set to: https://<your-railway-domain>.railway.app/api/__clerk
VITE_CLERK_PROXY_URL=https://your-domain.railway.app/api/__clerk

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── OpenAI (optional — used for AI advisor feature) ──────────────────────────
OPENAI_API_KEY=sk-...
